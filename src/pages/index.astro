---
export const prerender = true;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content="0; url=/top/1" />
    <title>HN — Hacker News</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #fafaf9;
        gap: 1.25rem;
        font-family: system-ui, -apple-system, sans-serif;
      }

      .logo-wrap {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .ring {
        position: absolute;
        width: 76px;
        height: 76px;
        border-radius: 50%;
        border: 3px solid #fed7aa;
        border-top-color: #f97316;
        animation: spin 0.75s linear infinite;
      }

      .badge {
        width: 48px;
        height: 48px;
        background: #f97316;
        border-radius: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: pulse 1.4s ease-in-out infinite;
      }

      .badge span {
        color: #fff;
        font-weight: 700;
        font-size: 1.2rem;
        letter-spacing: -0.03em;
      }

      .label {
        color: #9ca3af;
        font-size: 0.8125rem;
        letter-spacing: 0.04em;
      }

      @keyframes spin {
        to { transform: rotate(360deg); }
      }

      @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: 0.85; transform: scale(0.94); }
      }
    </style>
  </head>
  <body>
    <div class="logo-wrap">
      <div class="ring"></div>
      <div class="badge"><span>HN</span></div>
    </div>
    <p class="label">Loading…</p>
    <script>window.location.replace('/top/1');</script>
  </body>
</html>
